PORT=4000
DATABASE_URL=postgres://user:pass@localhost:5432/cierrescaja

# Alegra API - una cuenta independiente por sede
# El backend resuelve las credenciales segun la palabra clave (PASTO/MEDELLIN/ARMENIA/PEREIRA)
# que aparece en el nombre completo de la sede.
ALEGRA_PASTO_EMAIL=
ALEGRA_PASTO_TOKEN=
ALEGRA_MEDELLIN_EMAIL=
ALEGRA_MEDELLIN_TOKEN=
ALEGRA_ARMENIA_EMAIL=
ALEGRA_ARMENIA_TOKEN=
ALEGRA_PEREIRA_EMAIL=
ALEGRA_PEREIRA_TOKEN=

# Google service account (mismo del bot ConfirmadorComprobantes).
# Acepta el JSON crudo, o prefijo "base64:" + JSON codificado para evitar problemas con saltos de linea.
# Se usa para LEER la hoja de comprobantes (lectura).
GOOGLE_SERVICE_ACCOUNT_JSON=

# OAuth para escribir en Drive (los service accounts no tienen quota, por eso se requiere OAuth
# para subir archivos a Drive personal). Setup unico:
#   1) https://console.cloud.google.com/apis/credentials > Create > OAuth client ID > Web application
#   2) Authorized redirect URIs: http://localhost:8765/oauth/callback
#   3) Pega Client ID y Secret aqui
#   4) Corre: cd backend && node scripts/oauth-setup.js
#   5) Pega el refresh token en GOOGLE_OAUTH_REFRESH_TOKEN
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# IDs de carpetas raiz en Drive (una por sede). Compartir cada una con el service account como Editor.
DRIVE_FOLDER_PASTO=
DRIVE_FOLDER_MEDELLIN=
DRIVE_FOLDER_ARMENIA=
DRIVE_FOLDER_PEREIRA=
#
# Convencion UNIFORME (defaults en backend/config.js SEDE_DRIVE_DEFAULTS):
#   Mes: CIERRES {MES} {YYYY}        (ej: "CIERRES MAYO 2026")
#   Dia: CIERRE {DD}-{MM}-{YYYY}     (ej: "CIERRE 13-05-2026")
#   Gastos: subcarpeta "COMPROBANTES" dentro del dia
# El "padre" intermedio depende de cada sede (lo que ya existe en Drive):
#   PASTO    : <sede>/CIERRES MAYO 2026/CIERRE 13-05-2026/
#   MEDELLIN : <sede>/CIERRES MAYO 2026/CIERRE 13-05-2026/
#   ARMENIA  : <sede>/CIERRE CAJA/CIERRES MAYO 2026/CIERRE 13-05-2026/
#   PEREIRA  : <sede>/CIERRE DE CAJA/CIERRES MAYO 2026/CIERRE 13-05-2026/
#
# Tokens disponibles en los patrones:
#   {MES}=MAYO  {Mes}=Mayo  {mes}=mayo  {YYYY}  {YY}  {MM}  {M}  {DD}  {D}
#
# Override por env si en alguna sede quieres cambiar la convencion (descomentar y ajustar):
# DRIVE_PARENT_PASTO=
# DRIVE_MONTH_PATTERN_PASTO=CIERRES {MES}
# DRIVE_DAY_PATTERN_PASTO={DD}-{MM}
# DRIVE_CIERRE_SUBFOLDER_PASTO=
# DRIVE_GASTOS_SUBFOLDER_PASTO=COMPROBANTES

COMPROBANTES_SPREADSHEET_ID=

# Lista de sedes mostradas en la UI (separadas por coma)
SEDES=SMART GADGETS PASTO,SMART GADGETS MEDELLIN,SMART GADGETS ARMENIA,SMART GADGETS PEREIRA
